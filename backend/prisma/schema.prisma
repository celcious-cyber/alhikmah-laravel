generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model News {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  excerpt     String   @db.Text
  content     String   @db.LongText
  thumbnail   String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Gallery {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  caption   String?
  category  String   @default("umum")
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Pendaftaran {
  id                    BigInt   @id @default(autoincrement())
  no_registrasi         String?  @db.VarChar(255)
  email_pendaftar       String?  @db.VarChar(255)
  nama_lengkap          String   @db.VarChar(255)
  tempat_lahir          String?  @db.VarChar(255)
  tanggal_lahir         String?  @db.VarChar(255)
  jenis_kelamin         String?  @db.VarChar(255)
  nisn                  String?  @db.VarChar(255)
  nik                   String?  @db.VarChar(255)
  agama                 String?  @db.VarChar(255)
  hobi                  String?  @db.VarChar(255)
  cita_cita             String?  @db.VarChar(255)
  anak_ke               String?  @db.VarChar(255)
  jumlah_saudara_kandung String? @db.VarChar(255)
  alamat                String?  @db.Text
  rt_rw                 String?  @db.VarChar(255)
  dusun                 String?  @db.VarChar(255)
  desa                  String?  @db.VarChar(255)
  kecamatan             String?  @db.VarChar(255)
  kabupaten             String?  @db.VarChar(255)
  provinsi              String?  @db.VarChar(255)
  kode_pos              String?  @db.VarChar(255)
  no_kk                 String?  @db.VarChar(255)
  kepala_keluarga       String?  @db.VarChar(255)
  nama_ayah_kandung     String?  @db.VarChar(255)
  status_ayah           String?  @db.VarChar(255)
  alamat_ayah           String?  @db.VarChar(255)
  nik_ayah              String?  @db.VarChar(255)
  pekerjaan_ayah        String?  @db.VarChar(255)
  nama_ibu_kandung      String?  @db.VarChar(255)
  status_ibu            String?  @db.VarChar(255)
  nik_ibu               String?  @db.VarChar(255)
  pekerjaan_ibu         String?  @db.VarChar(255)
  alamat_ibu            String?  @db.VarChar(255)
  nama_wali             String?  @db.VarChar(255)
  nik_wali              String?  @db.VarChar(255)
  alamat_wali           String?  @db.VarChar(255)
  penghasilan           String?  @db.VarChar(255)
  no_kks                String?  @db.VarChar(255)
  no_pkh                String?  @db.VarChar(255)
  no_kip                String?  @db.VarChar(255)
  asal_sekolah          String?  @db.VarChar(255)
  npsn_sekolah          String?  @db.VarChar(255)
  alamat_sekolah        String?  @db.VarChar(255)
  no_surat_lulus        String?  @db.VarChar(255)
  no_blangko_ijazah     String?  @db.VarChar(255)
  nilai_rata2_ijazah    String?  @db.VarChar(255)
  foto_3x4              String?  @db.VarChar(255)
  file_ijazah           String?  @db.VarChar(255)
  file_surat_lulus      String?  @db.VarChar(255)
  file_akte_lahir       String?  @db.VarChar(255)
  file_kk               String?  @db.VarChar(255)
  file_kartu_nisn       String?  @db.VarChar(255)
  file_kartu_kip        String?  @db.VarChar(255)
  file_kartu_pkh        String?  @db.VarChar(255)
  file_kartu_kks        String?  @db.VarChar(255)
  file_foto_rapot       String?  @db.VarChar(255)
  verified              Boolean  @default(false)
  verified_by           String?  @db.VarChar(255)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@map("pendaftaran")
}

model Beasiswa {
  id                    BigInt   @id @default(autoincrement())
  no_registrasi         String?  @db.VarChar(255)
  jenis_beasiswa        String   @db.VarChar(255) // Akademik, Non-Akademik, Tahfidz, Tidak Mampu
  nama_lengkap          String   @db.VarChar(255)
  tempat_lahir          String?  @db.VarChar(255)
  tanggal_lahir         String?  @db.VarChar(255)
  email_pendaftar       String?  @db.VarChar(255)
  telepon               String?  @db.VarChar(255)
  asal_sekolah          String?  @db.VarChar(255)
  prestasi_deskripsi    String?  @db.Text
  file_sertifikat       String?  @db.VarChar(255) // Untuk Akademik/Non/Tahfidz
  file_sk_hafalan       String?  @db.VarChar(255) // Khusus Tahfidz
  file_sktm             String?  @db.VarChar(255) // Khusus Tidak Mampu
  file_rekomendasi      String?  @db.VarChar(255)
  file_komitmen         String?  @db.VarChar(255)
  verified              Boolean  @default(false)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@map("beasiswa")
}
